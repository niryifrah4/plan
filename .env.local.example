# ═══ Supabase ═══
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-KEY

# ═══ Google Calendar OAuth ═══
# 1. Go to https://console.cloud.google.com/apis/credentials
# 2. Create OAuth 2.0 Client ID (Web application)
# 3. Add http://localhost:3000/api/gcal/callback as authorized redirect URI
# 4. Enable Google Calendar API: https://console.cloud.google.com/apis/library/calendar-json.googleapis.com
GOOGLE_CLIENT_ID=YOUR-GOOGLE-CLIENT-ID.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=YOUR-GOOGLE-CLIENT-SECRET

# Optional: override redirect URI (defaults to {BASE_URL}/api/gcal/callback)
# GOOGLE_REDIRECT_URI=http://localhost:3000/api/gcal/callback

# ═══ App ═══
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# ═══ Security ═══
# PII encryption key — used by pgcrypto to encrypt ת״ז and יפוי כוח
# Generate a 32+ char random key: `openssl rand -base64 48`
# Set via Supabase SQL: ALTER DATABASE postgres SET app.pii_encryption_key = '<key>';
# PII_ENCRYPTION_KEY=YOUR-32-CHAR-RANDOM-KEY-HERE

# Session timeout (minutes) — default 15
# SESSION_IDLE_TIMEOUT_MIN=15

# Rate limit: max requests per minute per IP (upload/parse endpoints)
# RATE_LIMIT_UPLOAD=10
# RATE_LIMIT_PARSE=20
