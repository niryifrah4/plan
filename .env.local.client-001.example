# ─────────────────────────────────────────────────────────────
# Client #001 — dedicated Supabase project (isolated from dev)
# Copy to .env.local.client-001 and fill in values.
# To switch: `cp .env.local.client-001 .env.local && npm run dev`
# ─────────────────────────────────────────────────────────────

# ─── Supabase (client-001 project) ───
# Get from: supabase.com/dashboard → project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://REPLACE_WITH_CLIENT_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=REPLACE_WITH_ANON_KEY

# Service role — used ONLY by seed/admin scripts (never shipped to the browser).
SUPABASE_SERVICE_ROLE_KEY=REPLACE_WITH_SERVICE_ROLE_KEY

# Direct Postgres connection — used by run-all-migrations.mjs.
# Settings → Database → Connection string → URI (session pooler or direct).
# IMPORTANT: URL-encode special chars in the password.
DATABASE_URL=postgres://postgres:REPLACE_PASSWORD@db.REPLACE_PROJECT_REF.supabase.co:5432/postgres

# ─── App ───
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# ─── Demo seed (used once by seed-demo-advisor.mjs) ───
ADVISOR_EMAIL=nir@plan.co.il
ADVISOR_PASSWORD=CHANGE_ME_STRONG_PASSWORD
ADVISOR_NAME=ניר יפרח
SEED_DEMO_HOUSEHOLD=true
