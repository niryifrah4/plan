// Verdant Ledger — PostgreSQL Schema
// Run: npx prisma migrate dev --name init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Household (top-level entity) ───
model Household {
  id         String   @id @default(cuid())
  name       String
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  members    Member[]
  assets     Asset[]
  liabilities Liability[]
  securities Security[]
  cashflows  CashflowMonth[]
  goals      Goal[]
  documents  Document[]
  balanceSnapshots BalanceSnapshot[]
}

// ─── Family Members ───
model Member {
  id           String    @id @default(cuid())
  household_id String
  household    Household @relation(fields: [household_id], references: [id])
  name         String
  role         String    // "primary" | "spouse" | "child"
  birth_date   DateTime?
  created_at   DateTime  @default(now())
}

// ─── Assets ───
model Asset {
  id           String    @id @default(cuid())
  household_id String
  household    Household @relation(fields: [household_id], references: [id])
  asset_group  String    // "liquid" | "investments" | "pension" | "realestate"
  name         String
  balance      Float
  last_updated DateTime  @default(now())
  institution  String?
  account_ref  String?
  created_at   DateTime  @default(now())
  updated_at   DateTime  @updatedAt
}

// ─── Liabilities ───
model Liability {
  id              String    @id @default(cuid())
  household_id    String
  household       Household @relation(fields: [household_id], references: [id])
  liability_group String    // "mortgage" | "loans" | "cc"
  name            String
  balance         Float
  rate_pct        Float
  monthly_payment Float
  prepay_fee      Float     @default(0)
  from_scanner    Boolean   @default(false)
  created_at      DateTime  @default(now())
  updated_at      DateTime  @updatedAt
}

// ─── Securities (Investments Portfolio) ───
model Security {
  id              String    @id @default(cuid())
  household_id    String
  household       Household @relation(fields: [household_id], references: [id])
  kind            String    // "stock" | "etf" | "crypto" | "rsu" | "option" | "bond" | "fund"
  symbol          String
  broker          String
  currency        String    @default("USD")
  quantity        Float
  avg_cost        Float
  current_price   Float
  fx_rate_to_ils  Float     @default(3.72)
  cost_basis_ils  Float
  market_value_ils Float
  unrealized_pnl_ils Float
  unrealized_pnl_pct Float
  vest_date       DateTime?
  strike_price    Float?
  goal_id         String?   // linked goal
  goal_pct        Float?    // % allocated to goal
  created_at      DateTime  @default(now())
  updated_at      DateTime  @updatedAt
}

// ─── Cashflow Months ───
model CashflowMonth {
  id            String    @id @default(cuid())
  household_id  String
  household     Household @relation(fields: [household_id], references: [id])
  year          Int
  month         Int
  closed        Boolean   @default(false)
  income_total  Float
  expense_total Float
  cashflow_gap  Float
  created_at    DateTime  @default(now())
  updated_at    DateTime  @updatedAt

  @@unique([household_id, year, month])
}

// ─── Goals ───
model Goal {
  id              String    @id @default(cuid())
  household_id    String
  household       Household @relation(fields: [household_id], references: [id])
  name            String
  target_amount   Float
  target_date     DateTime
  lump_today      Float     @default(0)
  monthly_contrib Float     @default(0)
  annual_rate     Float     @default(0.05)
  priority        String    @default("medium") // "high" | "medium" | "low"
  instrument      String?
  investment_track String?
  planner_note    String?
  created_at      DateTime  @default(now())
  updated_at      DateTime  @updatedAt
}

// ─── Documents (uploaded files) ───
model Document {
  id           String    @id @default(cuid())
  household_id String
  household    Household @relation(fields: [household_id], references: [id])
  filename     String
  filepath     String    // relative path in uploads/
  mimetype     String
  size_bytes   Int
  doc_type     String?   // "bank_statement" | "payslip" | "tax_report" | "insurance" | "other"
  parsed       Boolean   @default(false)
  parsed_data  Json?     // extracted data from parser
  created_at   DateTime  @default(now())
  updated_at   DateTime  @updatedAt
}

// ─── Balance Snapshots (for growth chart / net worth over time) ───
model BalanceSnapshot {
  id           String    @id @default(cuid())
  household_id String
  household    Household @relation(fields: [household_id], references: [id])
  date         DateTime
  total_assets Float
  total_liab   Float
  net_worth    Float
  liquid       Float     @default(0)
  investments  Float     @default(0)
  pension      Float     @default(0)
  realestate   Float     @default(0)
  created_at   DateTime  @default(now())

  @@unique([household_id, date])
}
